---
import type { Locale } from "@/i18n/ui";
import { defaultLocale } from "@/i18n/ui";
import { t } from "@/i18n/utils";
import Hr from "./Hr.astro";
import Socials from "./Socials.astro";

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
const locale = (Astro.currentLocale || defaultLocale) as Locale;
---

<footer class:list={["w-full", { "mt-auto": !noMarginTop }]}>
  <Hr noPadding />
  <div
    class="flex flex-col items-center justify-between py-6 sm:flex-row-reverse sm:py-4"
  >
    <Socials centered />
    <div class="my-2 flex flex-col items-center whitespace-nowrap sm:flex-row">
      <a href="https://www.aliyun.com/" target="_blank" rel="noopener noreferrer" class="hover:text-accent">
        {t(locale, "footer.viewSource")}
      </a>
    </div>
  </div>
</footer>
