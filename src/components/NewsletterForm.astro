---
import { SITE, SOCIALS } from "@/config";

export interface Props {
  variant?: "default" | "compact";
}

const { variant = "default" } = Astro.props;
const activeSocials = SOCIALS.filter(({ active, href }) => active && href).slice(0, 3);
---

<div class={variant === 'default' ? 'newsletter-box bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-lg p-6 my-8' : 'newsletter-compact mt-6'}>
  {variant === 'default' && (
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
      Follow along for new posts, project notes, and updates from {SITE.title}.
    </p>
  )}
  <div class="flex flex-col sm:flex-row gap-3">
    {
      activeSocials.map((social) => (
        <a
          href={social.href}
          target={social.href.startsWith("http") ? "_blank" : undefined}
          rel={social.href.startsWith("http") ? "noopener noreferrer" : undefined}
          class="inline-flex items-center justify-center rounded-md border border-gray-300 px-4 py-2 text-sm hover:border-accent hover:text-accent dark:border-gray-600"
        >
          {social.name}
        </a>
      ))
    }
  </div>
  
  {variant === 'default' && (
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-3">
      No newsletter setup yet. RSS and social links are the current best way to keep up.
    </p>
  )}
</div>

<style>
  @media (max-width: 640px) {
    .newsletter-box {
      margin-left: -1rem;
      margin-right: -1rem;
      border-radius: 0;
    }
  }
</style>
