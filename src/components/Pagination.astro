---
import type { CollectionEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Page } from "astro";
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { defaultLocale, type Locale } from "@/i18n/ui";
import { stripTrailingSlash, t } from "@/i18n/utils";
import LinkButton from "./LinkButton.astro";

export interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
const locale = (Astro.currentLocale || defaultLocale) as Locale;

function getLocalizedUrl(url: string | undefined): string {
  if (!url) return "/";
  const path = url.toString().replace(/^\/(en|zh)\//, "/");
  return stripTrailingSlash(getRelativeLocaleUrl(locale, path));
}
---

{
  page.lastPage > 1 && (
    <nav class="mt-auto mb-8 flex justify-center" aria-label="Pagination">
      <LinkButton
        disabled={!page.url.prev}
        href={getLocalizedUrl(page.url.prev)}
        class:list={["mr-4 select-none", { "opacity-50": !page.url.prev }]}
        ariaLabel="Previous"
      >
        <IconArrowLeft class="inline-block" />
        {t(locale, "pagination.prev")}
      </LinkButton>
      {page.currentPage} / {page.lastPage}
      <LinkButton
        disabled={!page.url.next}
        href={getLocalizedUrl(page.url.next)}
        class:list={["ml-4 select-none", { "opacity-50": !page.url.next }]}
        ariaLabel="Next"
      >
        {t(locale, "pagination.next")}
        <IconArrowRight class="inline-block" />
      </LinkButton>
    </nav>
  )
}
